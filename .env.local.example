# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL
# Google OAuth redirect URI must be: ${NEXT_PUBLIC_BASE_URL}/api/admin/ga4/callback
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Google OAuth / GA4
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Supabase 개인 액세스 토큰 (마이그레이션/관리 스크립트용)
SUPABASE_ACCESS_TOKEN=your-personal-access-token

# Discord
DISCORD_FEEDBACK_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token
